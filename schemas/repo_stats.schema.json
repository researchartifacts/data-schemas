{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reprodb.github.io/data-schemas/schemas/repo_stats.schema.json",
  "title": "RepoStatsEntry Collection",
  "description": "Repository metrics for a single artifact.",
  "version": "0.1.0",
  "type": "array",
  "items": {
    "$ref": "#/$defs/RepoStatsEntry"
  },
  "$defs": {
    "RepoStatsEntry": {
      "additionalProperties": false,
      "description": "Repository metrics for a single artifact.",
      "properties": {
        "conference": {
          "description": "Conference abbreviation.",
          "title": "Conference",
          "type": "string"
        },
        "year": {
          "description": "Publication year.",
          "title": "Year",
          "type": "integer"
        },
        "title": {
          "description": "Paper title.",
          "title": "Title",
          "type": "string"
        },
        "url": {
          "description": "Repository or archive URL.",
          "title": "Url",
          "type": "string"
        },
        "source": {
          "description": "Platform hosting the artifact.",
          "enum": [
            "github",
            "zenodo",
            "figshare"
          ],
          "title": "Source",
          "type": "string"
        },
        "github_stars": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "GitHub star count.",
          "title": "Github Stars"
        },
        "github_forks": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "GitHub fork count.",
          "title": "Github Forks"
        },
        "zenodo_views": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Zenodo view count.",
          "title": "Zenodo Views"
        },
        "zenodo_downloads": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Zenodo download count.",
          "title": "Zenodo Downloads"
        },
        "description": {
          "anyOf": [
            {
              "maxLength": 120,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Repository description (truncated to 120 characters).",
          "title": "Description"
        },
        "language": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Primary programming language.",
          "title": "Language"
        },
        "name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Repository identifier (e.g., 'owner/repo').",
          "title": "Name"
        },
        "pushed_at": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Timestamp of last push in ISO 8601 format.",
          "title": "Pushed At"
        }
      },
      "required": [
        "conference",
        "year",
        "title",
        "url",
        "source"
      ],
      "title": "RepoStatsEntry",
      "type": "object"
    }
  }
}
