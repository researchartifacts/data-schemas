{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reprodb.github.io/data-schemas/schemas/repo_stats.schema.json",
  "title": "RepoStatsEntry Collection",
  "description": "Array of RepoStatsEntry records. Each element: GitHub/Zenodo repository metrics for a single artifact (stars, forks, views, downloads).",
  "version": "0.1.4",
  "type": "array",
  "items": {
    "$ref": "#/$defs/RepoStatsEntry"
  },
  "$defs": {
    "RepoStatsEntry": {
      "additionalProperties": false,
      "description": "GitHub/Zenodo repository metrics for a single artifact (stars, forks, views, downloads).",
      "properties": {
        "conference": {
          "description": "Conference abbreviation, e.g. 'OSDI', 'USENIXSEC'.",
          "examples": [
            "OSDI"
          ],
          "title": "Conference",
          "type": "string"
        },
        "year": {
          "description": "Publication year, e.g. 2023.",
          "examples": [
            2023
          ],
          "title": "Year",
          "type": "integer"
        },
        "title": {
          "description": "Full paper title associated with this repository.",
          "examples": [
            "Understanding and Detecting Software Upgrade Failures in Distributed Systems"
          ],
          "title": "Title",
          "type": "string"
        },
        "url": {
          "description": "Repository or archive URL, e.g. 'https://github.com/org/repo'.",
          "examples": [
            "https://github.com/org/repo"
          ],
          "title": "Url",
          "type": "string"
        },
        "source": {
          "description": "Platform hosting the artifact: 'GitHub', 'GitLab', 'Zenodo', 'Bitbucket', etc.",
          "enum": [
            "github",
            "zenodo",
            "figshare"
          ],
          "examples": [
            "github"
          ],
          "title": "Source",
          "type": "string"
        },
        "github_stars": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "GitHub star count at time of collection. Null for non-GitHub platforms.",
          "examples": [
            1250
          ],
          "title": "Github Stars"
        },
        "github_forks": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "GitHub fork count at time of collection. Null for non-GitHub platforms.",
          "examples": [
            340
          ],
          "title": "Github Forks"
        },
        "zenodo_views": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Zenodo page view count. Null for non-Zenodo platforms.",
          "examples": [
            5000
          ],
          "title": "Zenodo Views"
        },
        "zenodo_downloads": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Zenodo file download count. Null for non-Zenodo platforms.",
          "examples": [
            2000
          ],
          "title": "Zenodo Downloads"
        },
        "description": {
          "anyOf": [
            {
              "maxLength": 120,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Repository description from the hosting platform, truncated to 120 characters. Null if not available.",
          "examples": [
            "High-performance distributed key-value store"
          ],
          "title": "Description"
        },
        "language": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Primary programming language as reported by the platform, e.g. 'Python', 'C++'. Null if not available.",
          "examples": [
            "Python"
          ],
          "title": "Language"
        },
        "name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Repository identifier, e.g. 'microsoft/nni'. Null for non-GitHub/GitLab platforms.",
          "examples": [
            "Mathias Payer"
          ],
          "title": "Name"
        },
        "pushed_at": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "ISO 8601 timestamp of last push/update, e.g. '2024-07-15T10:30:00Z'. Null if not available.",
          "examples": [
            "2025-03-15T10:30:00Z"
          ],
          "title": "Pushed At"
        }
      },
      "required": [
        "conference",
        "year",
        "title",
        "url",
        "source"
      ],
      "title": "RepoStatsEntry",
      "type": "object"
    }
  }
}
