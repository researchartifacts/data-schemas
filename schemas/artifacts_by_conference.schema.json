{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reprodb.github.io/data-schemas/schemas/artifacts_by_conference.schema.json",
  "title": "ConferenceEntry Collection",
  "description": "Artifact counts and badge breakdowns for a single conference.",
  "version": "1.0.0",
  "type": "array",
  "items": {
    "$ref": "#/$defs/ConferenceEntry"
  },
  "$defs": {
    "YearBreakdown": {
      "additionalProperties": false,
      "description": "Per-year breakdown of artifact counts and badges.",
      "properties": {
        "year": {
          "description": "Publication year.",
          "title": "Year",
          "type": "integer"
        },
        "total": {
          "description": "Total artifacts for this conference-year.",
          "minimum": 0,
          "title": "Total",
          "type": "integer"
        },
        "available": {
          "description": "Count of 'available' badges.",
          "minimum": 0,
          "title": "Available",
          "type": "integer"
        },
        "functional": {
          "description": "Count of 'functional' badges.",
          "minimum": 0,
          "title": "Functional",
          "type": "integer"
        },
        "reproducible": {
          "description": "Count of 'reproduced' badges.",
          "minimum": 0,
          "title": "Reproducible",
          "type": "integer"
        },
        "reusable": {
          "description": "Count of 'reusable' badges.",
          "minimum": 0,
          "title": "Reusable",
          "type": "integer"
        }
      },
      "required": [
        "year",
        "total",
        "available",
        "functional",
        "reproducible",
        "reusable"
      ],
      "title": "YearBreakdown",
      "type": "object"
    },
    "ConferenceEntry": {
      "additionalProperties": false,
      "description": "Artifact counts and badge breakdowns for a single conference.",
      "properties": {
        "name": {
          "description": "Conference abbreviation.",
          "title": "Name",
          "type": "string"
        },
        "category": {
          "description": "Research domain.",
          "enum": [
            "systems",
            "security"
          ],
          "title": "Category",
          "type": "string"
        },
        "venue_type": {
          "description": "Whether this is a full conference or a workshop.",
          "enum": [
            "conference",
            "workshop"
          ],
          "title": "Venue Type",
          "type": "string"
        },
        "total_artifacts": {
          "description": "Total artifacts across all years.",
          "minimum": 0,
          "title": "Total Artifacts",
          "type": "integer"
        },
        "years": {
          "description": "Per-year breakdown of artifact counts and badges.",
          "items": {
            "$ref": "#/$defs/YearBreakdown"
          },
          "title": "Years",
          "type": "array"
        }
      },
      "required": [
        "name",
        "category",
        "venue_type",
        "total_artifacts",
        "years"
      ],
      "title": "ConferenceEntry",
      "type": "object"
    }
  }
}
