{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reprodb.github.io/data-schemas/schemas/summary.schema.json",
  "$comment": "Validates: _data/summary.yml, assets/data/summary.json",
  "version": "0.1.2",
  "additionalProperties": false,
  "description": "High-level summary: total artifact and conference counts, year range, and last-updated timestamp.",
  "properties": {
    "schema_version": {
      "description": "Semantic version of the data schema bundle, e.g. '0.1.1'.",
      "examples": [
        "0.1.2"
      ],
      "title": "Schema Version",
      "type": "string"
    },
    "total_artifacts": {
      "description": "Total number of evaluated artifacts across all conferences and years, e.g. 2831.",
      "examples": [
        2831
      ],
      "minimum": 0,
      "title": "Total Artifacts",
      "type": "integer"
    },
    "total_conferences": {
      "description": "Total number of tracked conferences, e.g. 13.",
      "examples": [
        13
      ],
      "minimum": 0,
      "title": "Total Conferences",
      "type": "integer"
    },
    "systems_artifacts": {
      "description": "Number of artifacts from systems conferences (ATC, EUROSYS, FAST, OSDI, SC, SOSP).",
      "minimum": 0,
      "title": "Systems Artifacts",
      "type": "integer"
    },
    "security_artifacts": {
      "description": "Number of artifacts from security conferences (ACSAC, CHES, NDSS, PETS, SYSTEX, USENIXSEC, WOOT).",
      "minimum": 0,
      "title": "Security Artifacts",
      "type": "integer"
    },
    "conferences_list": {
      "description": "All tracked conference abbreviations, e.g. ['ACSAC', 'ATC', 'CHES', ..., 'WOOT'].",
      "examples": [
        [
          "ACSAC",
          "ATC",
          "CHES",
          "EUROSYS",
          "FAST",
          "NDSS",
          "OSDI",
          "PETS",
          "SC",
          "SOSP",
          "SYSTEX",
          "USENIXSEC",
          "WOOT"
        ]
      ],
      "items": {
        "type": "string"
      },
      "title": "Conferences List",
      "type": "array"
    },
    "systems_conferences": {
      "description": "Systems conference abbreviations, e.g. ['ATC', 'EUROSYS', 'FAST', 'OSDI', 'SC', 'SOSP'].",
      "examples": [
        [
          "ATC",
          "EUROSYS",
          "FAST",
          "OSDI",
          "SC",
          "SOSP"
        ]
      ],
      "items": {
        "type": "string"
      },
      "title": "Systems Conferences",
      "type": "array"
    },
    "security_conferences": {
      "description": "Security conference abbreviations, e.g. ['ACSAC', 'CHES', 'NDSS', 'PETS', 'SYSTEX', 'USENIXSEC', 'WOOT'].",
      "examples": [
        [
          "ACSAC",
          "CHES",
          "NDSS",
          "PETS",
          "SYSTEX",
          "USENIXSEC",
          "WOOT"
        ]
      ],
      "items": {
        "type": "string"
      },
      "title": "Security Conferences",
      "type": "array"
    },
    "year_range": {
      "description": "Range of years covered, e.g. '2017-2026'.",
      "examples": [
        "2017-2026"
      ],
      "pattern": "^\\d{4}-\\d{4}$",
      "title": "Year Range",
      "type": "string"
    },
    "last_updated": {
      "description": "ISO 8601 UTC timestamp of last data update, e.g. '2026-04-27 21:26:06 UTC'.",
      "examples": [
        "2026-04-27 21:26:09 UTC"
      ],
      "title": "Last Updated",
      "type": "string"
    }
  },
  "required": [
    "schema_version",
    "total_artifacts",
    "total_conferences",
    "systems_artifacts",
    "security_artifacts",
    "conferences_list",
    "systems_conferences",
    "security_conferences",
    "year_range",
    "last_updated"
  ],
  "title": "Summary",
  "type": "object"
}
