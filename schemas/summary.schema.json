{
  "additionalProperties": false,
  "description": "High-level summary statistics for the Jekyll site.\n\nWritten as ``summary.yml`` in ``_data/``.",
  "properties": {
    "total_artifacts": {
      "description": "Total number of artifacts across all conferences.",
      "minimum": 0,
      "title": "Total Artifacts",
      "type": "integer"
    },
    "total_conferences": {
      "description": "Total number of tracked conferences.",
      "minimum": 0,
      "title": "Total Conferences",
      "type": "integer"
    },
    "systems_artifacts": {
      "description": "Artifacts from systems conferences.",
      "minimum": 0,
      "title": "Systems Artifacts",
      "type": "integer"
    },
    "security_artifacts": {
      "description": "Artifacts from security conferences.",
      "minimum": 0,
      "title": "Security Artifacts",
      "type": "integer"
    },
    "conferences_list": {
      "description": "List of all tracked conference abbreviations.",
      "items": {
        "type": "string"
      },
      "title": "Conferences List",
      "type": "array"
    },
    "systems_conferences": {
      "description": "List of systems conference abbreviations.",
      "items": {
        "type": "string"
      },
      "title": "Systems Conferences",
      "type": "array"
    },
    "security_conferences": {
      "description": "List of security conference abbreviations.",
      "items": {
        "type": "string"
      },
      "title": "Security Conferences",
      "type": "array"
    },
    "year_range": {
      "description": "Range of years covered in 'YYYY-YYYY' format.",
      "pattern": "^\\d{4}-\\d{4}$",
      "title": "Year Range",
      "type": "string"
    },
    "last_updated": {
      "description": "ISO 8601 UTC timestamp of last data update.",
      "title": "Last Updated",
      "type": "string"
    }
  },
  "required": [
    "total_artifacts",
    "total_conferences",
    "systems_artifacts",
    "security_artifacts",
    "conferences_list",
    "systems_conferences",
    "security_conferences",
    "year_range",
    "last_updated"
  ],
  "title": "Summary",
  "type": "object",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://researchartifacts.github.io/data-schemas/schemas/summary.schema.json"
}
