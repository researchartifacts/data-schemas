{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reprodb.github.io/data-schemas/schemas/artifacts.schema.json",
  "title": "Artifact Collection",
  "description": "A single research artifact associated with a conference paper.",
  "version": "1.0.0",
  "type": "array",
  "items": {
    "$ref": "#/$defs/Artifact"
  },
  "$defs": {
    "Artifact": {
      "additionalProperties": false,
      "description": "A single research artifact associated with a conference paper.",
      "properties": {
        "conference": {
          "description": "Conference abbreviation where the paper was published.",
          "enum": [
            "ACSAC",
            "ATC",
            "CHES",
            "EUROSYS",
            "FAST",
            "NDSS",
            "OSDI",
            "PETS",
            "SC",
            "SOSP",
            "SYSTEX",
            "USENIXSEC",
            "WOOT"
          ],
          "title": "Conference",
          "type": "string"
        },
        "category": {
          "description": "Research domain category.",
          "enum": [
            "systems",
            "security"
          ],
          "title": "Category",
          "type": "string"
        },
        "year": {
          "description": "Publication year.",
          "maximum": 2030,
          "minimum": 2017,
          "title": "Year",
          "type": "integer"
        },
        "title": {
          "description": "Paper title.",
          "title": "Title",
          "type": "string"
        },
        "badges": {
          "description": "Artifact evaluation badges. Canonical values: 'available', 'functional', 'reproduced', 'reusable', 'replicated'. Some conferences use non-normalized variants.",
          "items": {
            "type": "string"
          },
          "title": "Badges",
          "type": "array"
        },
        "artifact_urls": {
          "description": "All artifact-related URLs (repositories, archives, DOIs). Canonical field replacing repository_url, artifact_url, and github_url.",
          "items": {
            "type": "string"
          },
          "title": "Artifact Urls",
          "type": "array"
        },
        "doi": {
          "default": "",
          "description": "Canonical artifact DOI (e.g. '10.5281/zenodo.12345'). Extracted from artifact_urls.",
          "title": "Doi",
          "type": "string"
        },
        "paper_url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "DOI or direct link to the published paper.",
          "title": "Paper Url"
        },
        "appendix_url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "URL to supplementary materials or appendix.",
          "title": "Appendix Url"
        },
        "award": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Award designation, if any (e.g., 'Distinguished Artifact').",
          "title": "Award"
        }
      },
      "required": [
        "conference",
        "category",
        "year",
        "title",
        "badges",
        "artifact_urls"
      ],
      "title": "Artifact",
      "type": "object"
    }
  }
}
