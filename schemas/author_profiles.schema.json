{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reprodb.github.io/data-schemas/schemas/author_profiles.schema.json",
  "title": "AuthorProfile Collection",
  "description": "Array of AuthorProfile records. Each element: Unified author profile combining publication record, artifact metrics, and AE committee service.",
  "version": "0.1.1",
  "type": "array",
  "items": {
    "$ref": "#/$defs/AuthorProfile"
  },
  "$defs": {
    "AEMembership": {
      "additionalProperties": false,
      "description": "A single AE committee membership record.",
      "properties": {
        "conference": {
          "description": "Conference abbreviation (e.g. 'OSDI', 'USENIXSEC').",
          "title": "Conference",
          "type": "string"
        },
        "year": {
          "description": "Year of service.",
          "title": "Year",
          "type": "integer"
        },
        "role": {
          "description": "Role on the committee: 'chair' or 'member'.",
          "title": "Role",
          "type": "string"
        }
      },
      "required": [
        "conference",
        "year",
        "role"
      ],
      "title": "AEMembership",
      "type": "object"
    },
    "ArtifactPaper": {
      "additionalProperties": false,
      "description": "A paper that has an associated artifact evaluation.",
      "properties": {
        "title": {
          "description": "Paper title.",
          "title": "Title",
          "type": "string"
        },
        "conference": {
          "description": "Conference abbreviation.",
          "title": "Conference",
          "type": "string"
        },
        "year": {
          "description": "Publication year.",
          "title": "Year",
          "type": "integer"
        },
        "badges": {
          "description": "Artifact evaluation badges. Canonical values: 'available', 'functional', 'reproduced', 'reusable', 'replicated'.",
          "items": {
            "type": "string"
          },
          "title": "Badges",
          "type": "array"
        },
        "category": {
          "description": "Research domain.",
          "enum": [
            "systems",
            "security"
          ],
          "title": "Category",
          "type": "string"
        },
        "artifact_citations": {
          "description": "Citation count for this artifact.",
          "minimum": 0,
          "title": "Artifact Citations",
          "type": "integer"
        }
      },
      "required": [
        "title",
        "conference",
        "year",
        "badges",
        "category",
        "artifact_citations"
      ],
      "title": "ArtifactPaper",
      "type": "object"
    },
    "PlainPaper": {
      "additionalProperties": false,
      "description": "A published paper without an artifact evaluation.",
      "properties": {
        "title": {
          "description": "Paper title.",
          "title": "Title",
          "type": "string"
        },
        "conference": {
          "description": "Conference abbreviation.",
          "title": "Conference",
          "type": "string"
        },
        "year": {
          "description": "Publication year.",
          "title": "Year",
          "type": "integer"
        }
      },
      "required": [
        "title",
        "conference",
        "year"
      ],
      "title": "PlainPaper",
      "type": "object"
    },
    "AuthorProfile": {
      "additionalProperties": false,
      "description": "Unified author profile combining publication record, artifact metrics, and AE committee service.",
      "properties": {
        "name": {
          "description": "Full name in DBLP format (may include disambiguation suffix).",
          "title": "Name",
          "type": "string"
        },
        "affiliation": {
          "description": "Normalized institution affiliation.",
          "title": "Affiliation",
          "type": "string"
        },
        "papers": {
          "description": "Artifact papers authored.",
          "items": {
            "$ref": "#/$defs/ArtifactPaper"
          },
          "title": "Papers",
          "type": "array"
        },
        "papers_without_artifacts": {
          "description": "Papers by this author that do not have artifacts.",
          "items": {
            "$ref": "#/$defs/PlainPaper"
          },
          "title": "Papers Without Artifacts",
          "type": "array"
        },
        "conferences": {
          "description": "Conference abbreviations where author has published.",
          "items": {
            "type": "string"
          },
          "title": "Conferences",
          "type": "array"
        },
        "years": {
          "description": "Sorted list of years with activity.",
          "items": {
            "type": "integer"
          },
          "title": "Years",
          "type": "array"
        },
        "artifact_count": {
          "description": "Total artifacts authored.",
          "minimum": 0,
          "title": "Artifact Count",
          "type": "integer"
        },
        "total_papers": {
          "description": "Total papers at tracked conferences.",
          "minimum": 0,
          "title": "Total Papers",
          "type": "integer"
        },
        "artifact_pct": {
          "description": "Percentage of papers with artifacts.",
          "maximum": 100,
          "minimum": 0,
          "title": "Artifact Pct",
          "type": "number"
        },
        "artifact_citations": {
          "description": "Total citation count for artifacts.",
          "minimum": 0,
          "title": "Artifact Citations",
          "type": "integer"
        },
        "badges_available": {
          "description": "Count of 'available' badges across all artifacts.",
          "minimum": 0,
          "title": "Badges Available",
          "type": "integer"
        },
        "badges_functional": {
          "description": "Count of 'functional' badges across all artifacts.",
          "minimum": 0,
          "title": "Badges Functional",
          "type": "integer"
        },
        "badges_reproducible": {
          "description": "Count of 'reproduced' badges across all artifacts.",
          "minimum": 0,
          "title": "Badges Reproducible",
          "type": "integer"
        },
        "category": {
          "description": "Research domain based on conferences published at.",
          "enum": [
            "systems",
            "security",
            "both"
          ],
          "title": "Category",
          "type": "string"
        },
        "author_id": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Stable integer identifier referencing the canonical author_index.",
          "title": "Author Id"
        },
        "ae_memberships": {
          "default": 0,
          "description": "Number of AE committee memberships.",
          "minimum": 0,
          "title": "Ae Memberships",
          "type": "integer"
        },
        "chair_count": {
          "default": 0,
          "description": "Number of AE chair roles.",
          "minimum": 0,
          "title": "Chair Count",
          "type": "integer"
        },
        "ae_conferences": {
          "description": "AE committee memberships, one per conference-year served.",
          "items": {
            "$ref": "#/$defs/AEMembership"
          },
          "title": "Ae Conferences",
          "type": "array"
        },
        "ae_years": {
          "additionalProperties": {
            "type": "integer"
          },
          "description": "Year (as string, e.g. '2023') → number of AE memberships that year.",
          "title": "Ae Years",
          "type": "object"
        },
        "combined_score": {
          "description": "Total combined score.",
          "minimum": 0,
          "title": "Combined Score",
          "type": "integer"
        },
        "artifact_score": {
          "description": "Points from artifacts.",
          "minimum": 0,
          "title": "Artifact Score",
          "type": "integer"
        },
        "citation_score": {
          "description": "Points from citations.",
          "minimum": 0,
          "title": "Citation Score",
          "type": "integer"
        },
        "ae_score": {
          "description": "Points from AE service.",
          "minimum": 0,
          "title": "Ae Score",
          "type": "integer"
        },
        "rank": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Ranking position.",
          "title": "Rank"
        }
      },
      "required": [
        "name",
        "affiliation",
        "conferences",
        "years",
        "artifact_count",
        "total_papers",
        "artifact_pct",
        "artifact_citations",
        "badges_available",
        "badges_functional",
        "badges_reproducible",
        "category",
        "combined_score",
        "artifact_score",
        "citation_score",
        "ae_score"
      ],
      "title": "AuthorProfile",
      "type": "object"
    }
  }
}
