{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reprodb.github.io/data-schemas/schemas/institution_rankings.schema.json",
  "title": "InstitutionRanking Collection",
  "description": "Ranking entry for a single institution aggregating artifact and AE service metrics.",
  "version": "0.1.0",
  "type": "array",
  "items": {
    "$ref": "#/$defs/InstitutionRanking"
  },
  "$defs": {
    "TopAuthor": {
      "additionalProperties": false,
      "description": "Summary of a top-contributing author within an institution.",
      "properties": {
        "name": {
          "description": "Author name (may include DBLP disambiguation suffix).",
          "title": "Name",
          "type": "string"
        },
        "author_id": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Stable integer identifier referencing the canonical author_index.",
          "title": "Author Id"
        },
        "affiliation": {
          "description": "Author's institution affiliation.",
          "title": "Affiliation",
          "type": "string"
        },
        "combined_score": {
          "description": "Author's combined artifact + AE score.",
          "minimum": 0,
          "title": "Combined Score",
          "type": "integer"
        },
        "artifact_count": {
          "description": "Number of artifacts authored.",
          "minimum": 0,
          "title": "Artifact Count",
          "type": "integer"
        },
        "ae_memberships": {
          "description": "Number of AE committee memberships.",
          "minimum": 0,
          "title": "Ae Memberships",
          "type": "integer"
        },
        "total_papers": {
          "description": "Total papers at tracked conferences.",
          "minimum": 0,
          "title": "Total Papers",
          "type": "integer"
        }
      },
      "required": [
        "name",
        "affiliation",
        "combined_score",
        "artifact_count",
        "ae_memberships",
        "total_papers"
      ],
      "title": "TopAuthor",
      "type": "object"
    },
    "InstitutionRanking": {
      "additionalProperties": false,
      "description": "Ranking entry for a single institution aggregating artifact and AE service metrics.",
      "properties": {
        "affiliation": {
          "description": "Normalized institution name.",
          "title": "Affiliation",
          "type": "string"
        },
        "combined_score": {
          "description": "Total score combining artifact_score, citation_score, and ae_score.",
          "minimum": 3,
          "title": "Combined Score",
          "type": "integer"
        },
        "artifact_score": {
          "description": "Points from artifact contributions.",
          "minimum": 0,
          "title": "Artifact Score",
          "type": "integer"
        },
        "artifact_citations": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Total citation count for artifacts. Present when citation tracking is enabled.",
          "title": "Artifact Citations"
        },
        "citation_score": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Points from citations. Present when citation tracking is enabled.",
          "title": "Citation Score"
        },
        "ae_score": {
          "description": "Points from AE committee memberships (3 pts each) and chair roles (+2 pts each).",
          "minimum": 0,
          "title": "Ae Score",
          "type": "integer"
        },
        "ae_ratio": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Artifact-to-evaluation ratio. Null when ae_score is 0.",
          "title": "Ae Ratio"
        },
        "role": {
          "description": "Classification based on A:E ratio.",
          "enum": [
            "Producer",
            "Consumer",
            "Balanced"
          ],
          "title": "Role",
          "type": "string"
        },
        "artifact_count": {
          "description": "Total number of artifacts produced by this institution.",
          "minimum": 0,
          "title": "Artifact Count",
          "type": "integer"
        },
        "badges_functional": {
          "description": "Count of functional badges.",
          "minimum": 0,
          "title": "Badges Functional",
          "type": "integer"
        },
        "badges_reproducible": {
          "description": "Count of reproduced/replicated badges.",
          "minimum": 0,
          "title": "Badges Reproducible",
          "type": "integer"
        },
        "ae_memberships": {
          "description": "Number of AE committee memberships.",
          "minimum": 0,
          "title": "Ae Memberships",
          "type": "integer"
        },
        "chair_count": {
          "description": "Number of AE chair roles.",
          "minimum": 0,
          "title": "Chair Count",
          "type": "integer"
        },
        "total_papers": {
          "description": "Total DBLP paper count at tracked conferences.",
          "minimum": 0,
          "title": "Total Papers",
          "type": "integer"
        },
        "artifact_pct": {
          "description": "Percentage of papers with artifacts.",
          "maximum": 100,
          "minimum": 0,
          "title": "Artifact Pct",
          "type": "number"
        },
        "author_count": {
          "description": "Count of unique authors.",
          "minimum": 1,
          "title": "Author Count",
          "type": "integer"
        },
        "conferences": {
          "description": "List of conferences where the institution contributes.",
          "items": {
            "type": "string"
          },
          "title": "Conferences",
          "type": "array"
        },
        "years": {
          "additionalProperties": {
            "type": "integer"
          },
          "description": "Mapping of year (as string) to activity count.",
          "title": "Years",
          "type": "object"
        },
        "top_authors": {
          "description": "Top 20 authors from this institution, sorted by combined_score.",
          "items": {
            "$ref": "#/$defs/TopAuthor"
          },
          "maxItems": 20,
          "title": "Top Authors",
          "type": "array"
        }
      },
      "required": [
        "affiliation",
        "combined_score",
        "artifact_score",
        "ae_score",
        "role",
        "artifact_count",
        "badges_functional",
        "badges_reproducible",
        "ae_memberships",
        "chair_count",
        "total_papers",
        "artifact_pct",
        "author_count",
        "conferences",
        "years",
        "top_authors"
      ],
      "title": "InstitutionRanking",
      "type": "object"
    }
  }
}
