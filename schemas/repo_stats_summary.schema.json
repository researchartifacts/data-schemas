{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reprodb.github.io/data-schemas/schemas/repo_stats_summary.schema.json",
  "version": "0.1.2",
  "$defs": {
    "AreaRepoStats": {
      "additionalProperties": false,
      "description": "Repository metrics for a single research area (e.g. systems, security).",
      "properties": {
        "name": {
          "description": "Area name, e.g. 'systems' or 'security'.",
          "examples": [
            "systems"
          ],
          "title": "Name",
          "type": "string"
        },
        "github_repos": {
          "description": "Total GitHub repositories in this area.",
          "examples": [
            700
          ],
          "minimum": 0,
          "title": "Github Repos",
          "type": "integer"
        },
        "total_stars": {
          "description": "Sum of stars across all repos in this area.",
          "examples": [
            60000
          ],
          "minimum": 0,
          "title": "Total Stars",
          "type": "integer"
        },
        "total_forks": {
          "description": "Sum of forks across all repos in this area.",
          "examples": [
            15000
          ],
          "minimum": 0,
          "title": "Total Forks",
          "type": "integer"
        },
        "median_stars": {
          "description": "Median star count per repository.",
          "examples": [
            25.0
          ],
          "minimum": 0,
          "title": "Median Stars",
          "type": "number"
        },
        "median_forks": {
          "description": "Median fork count per repository.",
          "examples": [
            6.0
          ],
          "minimum": 0,
          "title": "Median Forks",
          "type": "number"
        },
        "p25_stars": {
          "description": "25th percentile of stars.",
          "examples": [
            8.0
          ],
          "minimum": 0,
          "title": "P25 Stars",
          "type": "number"
        },
        "p75_stars": {
          "description": "75th percentile of stars.",
          "examples": [
            80.0
          ],
          "minimum": 0,
          "title": "P75 Stars",
          "type": "number"
        },
        "p25_forks": {
          "description": "25th percentile of forks.",
          "examples": [
            2.0
          ],
          "minimum": 0,
          "title": "P25 Forks",
          "type": "number"
        },
        "p75_forks": {
          "description": "75th percentile of forks.",
          "examples": [
            18.0
          ],
          "minimum": 0,
          "title": "P75 Forks",
          "type": "number"
        },
        "max_stars": {
          "description": "Maximum star count in this area.",
          "examples": [
            5200
          ],
          "minimum": 0,
          "title": "Max Stars",
          "type": "integer"
        }
      },
      "required": [
        "name",
        "github_repos",
        "total_stars",
        "total_forks",
        "median_stars",
        "median_forks",
        "p25_stars",
        "p75_stars",
        "p25_forks",
        "p75_forks",
        "max_stars"
      ],
      "title": "AreaRepoStats",
      "type": "object"
    },
    "ConferenceRepoStats": {
      "additionalProperties": false,
      "description": "Repository metrics grouped by conference.",
      "properties": {
        "name": {
          "description": "Conference abbreviation, e.g. 'ACSAC', 'OSDI'.",
          "examples": [
            "Mathias Payer"
          ],
          "title": "Name",
          "type": "string"
        },
        "github_repos": {
          "description": "Total GitHub repositories across all years for this conference.",
          "examples": [
            180
          ],
          "minimum": 0,
          "title": "Github Repos",
          "type": "integer"
        },
        "total_stars": {
          "description": "Sum of GitHub stars across all repos for this conference.",
          "examples": [
            45000
          ],
          "minimum": 0,
          "title": "Total Stars",
          "type": "integer"
        },
        "total_forks": {
          "description": "Sum of GitHub forks across all repos for this conference.",
          "examples": [
            12000
          ],
          "minimum": 0,
          "title": "Total Forks",
          "type": "integer"
        },
        "avg_stars": {
          "description": "Mean star count per repository for this conference.",
          "examples": [
            250.5
          ],
          "minimum": 0,
          "title": "Avg Stars",
          "type": "number"
        },
        "avg_forks": {
          "description": "Mean fork count per repository for this conference.",
          "examples": [
            65.3
          ],
          "minimum": 0,
          "title": "Avg Forks",
          "type": "number"
        },
        "max_stars": {
          "description": "Maximum star count among all repos for this conference.",
          "examples": [
            5200
          ],
          "minimum": 0,
          "title": "Max Stars",
          "type": "integer"
        },
        "max_forks": {
          "description": "Maximum fork count among all repos for this conference.",
          "examples": [
            1300
          ],
          "minimum": 0,
          "title": "Max Forks",
          "type": "integer"
        },
        "years": {
          "description": "Per-year repository metrics, ordered chronologically.",
          "examples": [
            [
              2021,
              2022,
              2023
            ]
          ],
          "items": {
            "$ref": "#/$defs/ConferenceYearStats"
          },
          "title": "Years",
          "type": "array"
        },
        "top_repos": {
          "description": "Highlighted repositories for this conference, sorted by stars descending.",
          "items": {
            "$ref": "#/$defs/TopRepo"
          },
          "title": "Top Repos",
          "type": "array"
        }
      },
      "required": [
        "name",
        "github_repos",
        "total_stars",
        "total_forks",
        "avg_stars",
        "avg_forks",
        "max_stars",
        "max_forks"
      ],
      "title": "ConferenceRepoStats",
      "type": "object"
    },
    "ConferenceYearStats": {
      "description": "Repository metrics for a single conference-year.",
      "properties": {
        "year": {
          "description": "Publication year, e.g. 2023.",
          "examples": [
            2023
          ],
          "title": "Year",
          "type": "integer"
        },
        "github_repos": {
          "description": "Number of GitHub repositories for this conference-year.",
          "examples": [
            180
          ],
          "minimum": 0,
          "title": "Github Repos",
          "type": "integer"
        },
        "total_stars": {
          "description": "Sum of GitHub stars across all repos for this conference-year.",
          "examples": [
            45000
          ],
          "minimum": 0,
          "title": "Total Stars",
          "type": "integer"
        },
        "total_forks": {
          "description": "Sum of GitHub forks across all repos for this conference-year.",
          "examples": [
            12000
          ],
          "minimum": 0,
          "title": "Total Forks",
          "type": "integer"
        },
        "avg_stars": {
          "description": "Mean star count per repository for this conference-year.",
          "examples": [
            250.5
          ],
          "minimum": 0,
          "title": "Avg Stars",
          "type": "number"
        },
        "avg_forks": {
          "description": "Mean fork count per repository for this conference-year.",
          "examples": [
            65.3
          ],
          "minimum": 0,
          "title": "Avg Forks",
          "type": "number"
        }
      },
      "required": [
        "year",
        "github_repos",
        "total_stars",
        "total_forks",
        "avg_stars",
        "avg_forks"
      ],
      "title": "ConferenceYearStats",
      "type": "object"
    },
    "OverallStats": {
      "additionalProperties": false,
      "description": "Global repository metrics.",
      "properties": {
        "github_repos": {
          "description": "Total GitHub repositories across all conferences, e.g. 1344.",
          "examples": [
            180
          ],
          "minimum": 0,
          "title": "Github Repos",
          "type": "integer"
        },
        "total_stars": {
          "description": "Sum of GitHub stars across all repositories, e.g. 126724.",
          "examples": [
            45000
          ],
          "minimum": 0,
          "title": "Total Stars",
          "type": "integer"
        },
        "total_forks": {
          "description": "Sum of GitHub forks across all repositories.",
          "examples": [
            12000
          ],
          "minimum": 0,
          "title": "Total Forks",
          "type": "integer"
        },
        "max_stars": {
          "description": "Maximum star count among all repositories.",
          "examples": [
            5200
          ],
          "minimum": 0,
          "title": "Max Stars",
          "type": "integer"
        },
        "max_forks": {
          "description": "Maximum fork count among all repositories.",
          "examples": [
            1300
          ],
          "minimum": 0,
          "title": "Max Forks",
          "type": "integer"
        },
        "zenodo_repos": {
          "description": "Total Zenodo-hosted artifact records, e.g. 902.",
          "examples": [
            45
          ],
          "minimum": 0,
          "title": "Zenodo Repos",
          "type": "integer"
        },
        "total_views": {
          "description": "Sum of Zenodo page views across all records.",
          "examples": [
            85000
          ],
          "minimum": 0,
          "title": "Total Views",
          "type": "integer"
        },
        "total_downloads": {
          "description": "Sum of Zenodo file downloads across all records.",
          "examples": [
            32000
          ],
          "minimum": 0,
          "title": "Total Downloads",
          "type": "integer"
        },
        "avg_stars": {
          "description": "Mean GitHub star count per repository, e.g. 94.3.",
          "examples": [
            250.5
          ],
          "minimum": 0,
          "title": "Avg Stars",
          "type": "number"
        },
        "avg_forks": {
          "description": "Mean GitHub fork count per repository, e.g. 12.3.",
          "examples": [
            65.3
          ],
          "minimum": 0,
          "title": "Avg Forks",
          "type": "number"
        },
        "last_updated": {
          "description": "ISO 8601 UTC timestamp of when the stats were collected, e.g. '2026-04-27 21:26:09 UTC'.",
          "examples": [
            "2026-04-27 21:26:09 UTC"
          ],
          "title": "Last Updated",
          "type": "string"
        }
      },
      "required": [
        "github_repos",
        "total_stars",
        "total_forks",
        "max_stars",
        "max_forks",
        "zenodo_repos",
        "total_views",
        "total_downloads",
        "avg_stars",
        "avg_forks",
        "last_updated"
      ],
      "title": "OverallStats",
      "type": "object"
    },
    "TopRepo": {
      "description": "A top repository within a conference.",
      "properties": {
        "name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Repository identifier, e.g. 'microsoft/nni'. Null if unknown.",
          "examples": [
            "Mathias Payer"
          ],
          "title": "Name"
        },
        "url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Repository URL, e.g. 'https://github.com/microsoft/nni'. Null if unknown.",
          "examples": [
            "https://github.com/org/repo"
          ],
          "title": "Url"
        },
        "stars": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "GitHub star count. Null if not available.",
          "examples": [
            1250
          ],
          "title": "Stars"
        },
        "forks": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "GitHub fork count. Null if not available.",
          "examples": [
            340
          ],
          "title": "Forks"
        },
        "language": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Primary programming language, e.g. 'Python'. Null if unknown.",
          "examples": [
            "Python"
          ],
          "title": "Language"
        },
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Short repository description. Null if not set.",
          "examples": [
            "High-performance distributed key-value store"
          ],
          "title": "Description"
        }
      },
      "title": "TopRepo",
      "type": "object"
    },
    "YearRepoStats": {
      "additionalProperties": false,
      "description": "Repository metrics grouped by year.",
      "properties": {
        "year": {
          "description": "Publication year, e.g. 2023.",
          "examples": [
            2023
          ],
          "title": "Year",
          "type": "integer"
        },
        "github_repos": {
          "description": "Number of GitHub repositories for this year across all conferences.",
          "examples": [
            180
          ],
          "minimum": 0,
          "title": "Github Repos",
          "type": "integer"
        },
        "total_stars": {
          "description": "Sum of GitHub stars across all repos for this year.",
          "examples": [
            45000
          ],
          "minimum": 0,
          "title": "Total Stars",
          "type": "integer"
        },
        "total_forks": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Sum of GitHub forks. Null if not tracked for this year.",
          "examples": [
            12000
          ],
          "title": "Total Forks"
        },
        "max_stars": {
          "default": 0,
          "description": "Maximum star count among all repos for this year.",
          "examples": [
            5200
          ],
          "minimum": 0,
          "title": "Max Stars",
          "type": "integer"
        },
        "max_forks": {
          "default": 0,
          "description": "Maximum fork count among all repos for this year.",
          "examples": [
            1300
          ],
          "minimum": 0,
          "title": "Max Forks",
          "type": "integer"
        },
        "avg_stars": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Mean star count per repository. Null if not computed.",
          "examples": [
            250.5
          ],
          "title": "Avg Stars"
        },
        "avg_forks": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Mean fork count per repository. Null if not computed.",
          "examples": [
            65.3
          ],
          "title": "Avg Forks"
        }
      },
      "required": [
        "year",
        "github_repos",
        "total_stars"
      ],
      "title": "YearRepoStats",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Aggregated repository metrics: overall stats, per-conference breakdowns, and yearly trends.",
  "properties": {
    "overall": {
      "$ref": "#/$defs/OverallStats",
      "description": "Global repository metrics across all conferences and years."
    },
    "by_conference": {
      "description": "Repository metrics grouped by conference, each with per-year breakdown.",
      "items": {
        "$ref": "#/$defs/ConferenceRepoStats"
      },
      "title": "By Conference",
      "type": "array"
    },
    "by_year": {
      "description": "Repository metrics grouped by year across all conferences, ordered chronologically.",
      "items": {
        "$ref": "#/$defs/YearRepoStats"
      },
      "title": "By Year",
      "type": "array"
    },
    "by_area": {
      "description": "Repository metrics grouped by research area (systems, security).",
      "items": {
        "$ref": "#/$defs/AreaRepoStats"
      },
      "title": "By Area",
      "type": "array"
    }
  },
  "required": [
    "overall",
    "by_conference",
    "by_year"
  ],
  "title": "RepoStatsSummary",
  "type": "object"
}
