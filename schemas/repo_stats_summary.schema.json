{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://researchartifacts.github.io/data-schemas/schemas/repo_stats_summary.schema.json",
  "title": "Repository Statistics Summary",
  "description": "Aggregated repository metrics for the Jekyll site. Written as repo_stats.yml in _data/.",
  "type": "object",
  "required": ["overall", "by_conference", "by_year"],
  "properties": {
    "overall": {
      "type": "object",
      "description": "Global repository metrics.",
      "required": [
        "github_repos", "total_stars", "total_forks",
        "max_stars", "max_forks",
        "zenodo_repos", "total_views", "total_downloads",
        "avg_stars", "avg_forks", "last_updated"
      ],
      "properties": {
        "github_repos": { "type": "integer", "minimum": 0 },
        "total_stars": { "type": "integer", "minimum": 0 },
        "total_forks": { "type": "integer", "minimum": 0 },
        "max_stars": { "type": "integer", "minimum": 0 },
        "max_forks": { "type": "integer", "minimum": 0 },
        "zenodo_repos": { "type": "integer", "minimum": 0 },
        "total_views": { "type": "integer", "minimum": 0 },
        "total_downloads": { "type": "integer", "minimum": 0 },
        "avg_stars": { "type": "number", "minimum": 0 },
        "avg_forks": { "type": "number", "minimum": 0 },
        "last_updated": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    },
    "by_conference": {
      "type": "array",
      "description": "Repository metrics grouped by conference.",
      "items": {
        "type": "object",
        "required": ["name", "github_repos", "total_stars", "total_forks", "avg_stars", "avg_forks", "max_stars", "max_forks"],
        "properties": {
          "name": { "type": "string" },
          "github_repos": { "type": "integer", "minimum": 0 },
          "total_stars": { "type": "integer", "minimum": 0 },
          "total_forks": { "type": "integer", "minimum": 0 },
          "avg_stars": { "type": "number", "minimum": 0 },
          "avg_forks": { "type": "number", "minimum": 0 },
          "max_stars": { "type": "integer", "minimum": 0 },
          "max_forks": { "type": "integer", "minimum": 0 },
          "years": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "year": { "type": "integer" },
                "github_repos": { "type": "integer", "minimum": 0 },
                "total_stars": { "type": "integer", "minimum": 0 },
                "total_forks": { "type": "integer", "minimum": 0 },
                "avg_stars": { "type": "number", "minimum": 0 },
                "avg_forks": { "type": "number", "minimum": 0 }
              }
            }
          },
          "top_repos": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "url": { "type": "string", "format": "uri" },
                "stars": { "type": "integer", "minimum": 0 },
                "forks": { "type": "integer", "minimum": 0 },
                "language": { "type": "string" },
                "description": { "type": "string" }
              }
            }
          }
        },
        "additionalProperties": false
      }
    },
    "by_year": {
      "type": "array",
      "description": "Repository metrics grouped by year.",
      "items": {
        "type": "object",
        "required": ["year", "github_repos", "total_stars"],
        "properties": {
          "year": { "type": "integer" },
          "github_repos": { "type": "integer", "minimum": 0 },
          "total_stars": { "type": "integer", "minimum": 0 },
          "total_forks": { "type": "integer", "minimum": 0 },
          "avg_stars": { "type": "number", "minimum": 0 },
          "avg_forks": { "type": "number", "minimum": 0 }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
