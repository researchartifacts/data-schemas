{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reprodb.github.io/data-schemas/schemas/repo_stats_summary.schema.json",
  "version": "0.1.2",
  "$defs": {
    "ConferenceRepoStats": {
      "additionalProperties": false,
      "description": "Repository metrics grouped by conference.",
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "github_repos": {
          "minimum": 0,
          "title": "Github Repos",
          "type": "integer"
        },
        "total_stars": {
          "minimum": 0,
          "title": "Total Stars",
          "type": "integer"
        },
        "total_forks": {
          "minimum": 0,
          "title": "Total Forks",
          "type": "integer"
        },
        "avg_stars": {
          "minimum": 0,
          "title": "Avg Stars",
          "type": "number"
        },
        "avg_forks": {
          "minimum": 0,
          "title": "Avg Forks",
          "type": "number"
        },
        "max_stars": {
          "minimum": 0,
          "title": "Max Stars",
          "type": "integer"
        },
        "max_forks": {
          "minimum": 0,
          "title": "Max Forks",
          "type": "integer"
        },
        "years": {
          "items": {
            "$ref": "#/$defs/ConferenceYearStats"
          },
          "title": "Years",
          "type": "array"
        },
        "top_repos": {
          "items": {
            "$ref": "#/$defs/TopRepo"
          },
          "title": "Top Repos",
          "type": "array"
        }
      },
      "required": [
        "name",
        "github_repos",
        "total_stars",
        "total_forks",
        "avg_stars",
        "avg_forks",
        "max_stars",
        "max_forks"
      ],
      "title": "ConferenceRepoStats",
      "type": "object"
    },
    "ConferenceYearStats": {
      "description": "Repository metrics for a single conference-year.",
      "properties": {
        "year": {
          "title": "Year",
          "type": "integer"
        },
        "github_repos": {
          "minimum": 0,
          "title": "Github Repos",
          "type": "integer"
        },
        "total_stars": {
          "minimum": 0,
          "title": "Total Stars",
          "type": "integer"
        },
        "total_forks": {
          "minimum": 0,
          "title": "Total Forks",
          "type": "integer"
        },
        "avg_stars": {
          "minimum": 0,
          "title": "Avg Stars",
          "type": "number"
        },
        "avg_forks": {
          "minimum": 0,
          "title": "Avg Forks",
          "type": "number"
        }
      },
      "required": [
        "year",
        "github_repos",
        "total_stars",
        "total_forks",
        "avg_stars",
        "avg_forks"
      ],
      "title": "ConferenceYearStats",
      "type": "object"
    },
    "OverallStats": {
      "additionalProperties": false,
      "description": "Global repository metrics.",
      "properties": {
        "github_repos": {
          "minimum": 0,
          "title": "Github Repos",
          "type": "integer"
        },
        "total_stars": {
          "minimum": 0,
          "title": "Total Stars",
          "type": "integer"
        },
        "total_forks": {
          "minimum": 0,
          "title": "Total Forks",
          "type": "integer"
        },
        "max_stars": {
          "minimum": 0,
          "title": "Max Stars",
          "type": "integer"
        },
        "max_forks": {
          "minimum": 0,
          "title": "Max Forks",
          "type": "integer"
        },
        "zenodo_repos": {
          "minimum": 0,
          "title": "Zenodo Repos",
          "type": "integer"
        },
        "total_views": {
          "minimum": 0,
          "title": "Total Views",
          "type": "integer"
        },
        "total_downloads": {
          "minimum": 0,
          "title": "Total Downloads",
          "type": "integer"
        },
        "avg_stars": {
          "minimum": 0,
          "title": "Avg Stars",
          "type": "number"
        },
        "avg_forks": {
          "minimum": 0,
          "title": "Avg Forks",
          "type": "number"
        },
        "last_updated": {
          "description": "ISO 8601 UTC timestamp of when the stats were collected.",
          "title": "Last Updated",
          "type": "string"
        }
      },
      "required": [
        "github_repos",
        "total_stars",
        "total_forks",
        "max_stars",
        "max_forks",
        "zenodo_repos",
        "total_views",
        "total_downloads",
        "avg_stars",
        "avg_forks",
        "last_updated"
      ],
      "title": "OverallStats",
      "type": "object"
    },
    "TopRepo": {
      "description": "A top repository within a conference.",
      "properties": {
        "name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Name"
        },
        "url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Url"
        },
        "stars": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Stars"
        },
        "forks": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Forks"
        },
        "language": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Language"
        },
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Description"
        }
      },
      "title": "TopRepo",
      "type": "object"
    },
    "YearRepoStats": {
      "additionalProperties": false,
      "description": "Repository metrics grouped by year.",
      "properties": {
        "year": {
          "title": "Year",
          "type": "integer"
        },
        "github_repos": {
          "minimum": 0,
          "title": "Github Repos",
          "type": "integer"
        },
        "total_stars": {
          "minimum": 0,
          "title": "Total Stars",
          "type": "integer"
        },
        "total_forks": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Total Forks"
        },
        "max_stars": {
          "default": 0,
          "minimum": 0,
          "title": "Max Stars",
          "type": "integer"
        },
        "max_forks": {
          "default": 0,
          "minimum": 0,
          "title": "Max Forks",
          "type": "integer"
        },
        "avg_stars": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Avg Stars"
        },
        "avg_forks": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Avg Forks"
        }
      },
      "required": [
        "year",
        "github_repos",
        "total_stars"
      ],
      "title": "YearRepoStats",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Aggregated repository metrics: overall stats, per-conference breakdowns, and yearly trends.",
  "properties": {
    "overall": {
      "$ref": "#/$defs/OverallStats"
    },
    "by_conference": {
      "items": {
        "$ref": "#/$defs/ConferenceRepoStats"
      },
      "title": "By Conference",
      "type": "array"
    },
    "by_year": {
      "items": {
        "$ref": "#/$defs/YearRepoStats"
      },
      "title": "By Year",
      "type": "array"
    }
  },
  "required": [
    "overall",
    "by_conference",
    "by_year"
  ],
  "title": "RepoStatsSummary",
  "type": "object"
}
