{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reprodb.github.io/data-schemas/schemas/author_stats.schema.json",
  "title": "AuthorStats Collection",
  "description": "Complete statistics for a single author.\n\nGenerated by ``generate_author_stats.py``.",
  "version": "0.1.0",
  "type": "array",
  "items": {
    "$ref": "#/$defs/AuthorStats"
  },
  "$defs": {
    "ArtifactPaper": {
      "additionalProperties": false,
      "description": "A paper that has an associated artifact evaluation.",
      "properties": {
        "title": {
          "description": "Paper title.",
          "title": "Title",
          "type": "string"
        },
        "conference": {
          "description": "Conference abbreviation.",
          "title": "Conference",
          "type": "string"
        },
        "year": {
          "description": "Publication year.",
          "title": "Year",
          "type": "integer"
        },
        "badges": {
          "description": "Artifact evaluation badges. Canonical values: 'available', 'functional', 'reproduced', 'reusable', 'replicated'.",
          "items": {
            "type": "string"
          },
          "title": "Badges",
          "type": "array"
        },
        "category": {
          "description": "Research domain.",
          "enum": [
            "systems",
            "security"
          ],
          "title": "Category",
          "type": "string"
        },
        "artifact_citations": {
          "description": "Citation count for this artifact.",
          "minimum": 0,
          "title": "Artifact Citations",
          "type": "integer"
        }
      },
      "required": [
        "title",
        "conference",
        "year",
        "badges",
        "category",
        "artifact_citations"
      ],
      "title": "ArtifactPaper",
      "type": "object"
    },
    "PlainPaper": {
      "additionalProperties": false,
      "description": "A published paper without an artifact evaluation.",
      "properties": {
        "title": {
          "description": "Paper title.",
          "title": "Title",
          "type": "string"
        },
        "conference": {
          "description": "Conference abbreviation.",
          "title": "Conference",
          "type": "string"
        },
        "year": {
          "description": "Publication year.",
          "title": "Year",
          "type": "integer"
        }
      },
      "required": [
        "title",
        "conference",
        "year"
      ],
      "title": "PlainPaper",
      "type": "object"
    },
    "AuthorStats": {
      "additionalProperties": false,
      "description": "Complete statistics for a single author.\n\nGenerated by ``generate_author_stats.py``.",
      "properties": {
        "name": {
          "description": "Full name in DBLP format (may include disambiguation suffix).",
          "title": "Name",
          "type": "string"
        },
        "affiliation": {
          "description": "Normalized institution affiliation.",
          "title": "Affiliation",
          "type": "string"
        },
        "papers": {
          "description": "Artifact papers authored.",
          "items": {
            "$ref": "#/$defs/ArtifactPaper"
          },
          "title": "Papers",
          "type": "array"
        },
        "papers_without_artifacts": {
          "description": "Papers by this author that do not have artifacts.",
          "items": {
            "$ref": "#/$defs/PlainPaper"
          },
          "title": "Papers Without Artifacts",
          "type": "array"
        },
        "conferences": {
          "description": "Conference abbreviations where author has published.",
          "items": {
            "type": "string"
          },
          "title": "Conferences",
          "type": "array"
        },
        "years": {
          "description": "Sorted list of years with activity.",
          "items": {
            "type": "integer"
          },
          "title": "Years",
          "type": "array"
        },
        "artifact_count": {
          "description": "Total artifacts authored.",
          "minimum": 0,
          "title": "Artifact Count",
          "type": "integer"
        },
        "total_papers": {
          "description": "Total papers at tracked conferences.",
          "minimum": 0,
          "title": "Total Papers",
          "type": "integer"
        },
        "artifact_pct": {
          "description": "Percentage of papers with artifacts.",
          "maximum": 100,
          "minimum": 0,
          "title": "Artifact Pct",
          "type": "number"
        },
        "artifact_citations": {
          "description": "Total citation count for artifacts.",
          "minimum": 0,
          "title": "Artifact Citations",
          "type": "integer"
        },
        "badges_available": {
          "description": "Count of 'available' badges across all artifacts.",
          "minimum": 0,
          "title": "Badges Available",
          "type": "integer"
        },
        "badges_functional": {
          "description": "Count of 'functional' badges across all artifacts.",
          "minimum": 0,
          "title": "Badges Functional",
          "type": "integer"
        },
        "badges_reproducible": {
          "description": "Count of 'reproduced' badges across all artifacts.",
          "minimum": 0,
          "title": "Badges Reproducible",
          "type": "integer"
        },
        "category": {
          "description": "Research domain based on conferences published at.",
          "enum": [
            "systems",
            "security",
            "both",
            "unknown"
          ],
          "title": "Category",
          "type": "string"
        },
        "author_id": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Stable integer identifier referencing the canonical author_index.",
          "title": "Author Id"
        },
        "display_name": {
          "description": "Name without DBLP disambiguation suffix.",
          "title": "Display Name",
          "type": "string"
        },
        "total_papers_by_conf": {
          "additionalProperties": {
            "type": "integer"
          },
          "description": "Mapping of conference name to paper count at that conference.",
          "title": "Total Papers By Conf",
          "type": "object"
        },
        "total_papers_by_conf_year": {
          "additionalProperties": {
            "additionalProperties": {
              "type": "integer"
            },
            "type": "object"
          },
          "description": "Nested mapping: conference name → { year → count }.",
          "title": "Total Papers By Conf Year",
          "type": "object"
        },
        "repro_pct": {
          "description": "Percentage of artifacts with a reproducibility badge.",
          "maximum": 100,
          "minimum": 0,
          "title": "Repro Pct",
          "type": "number"
        },
        "functional_pct": {
          "description": "Percentage of artifacts with a functional badge.",
          "maximum": 100,
          "minimum": 0,
          "title": "Functional Pct",
          "type": "number"
        },
        "year_range": {
          "description": "Activity range in 'YYYY-YYYY' format.",
          "pattern": "^\\d{4}-\\d{4}$",
          "title": "Year Range",
          "type": "string"
        },
        "recent_count": {
          "description": "Number of papers in the last 3 years.",
          "minimum": 0,
          "title": "Recent Count",
          "type": "integer"
        },
        "paper_ids": {
          "description": "List of paper index IDs for artifact papers. References papers.json.",
          "items": {
            "type": "integer"
          },
          "title": "Paper Ids",
          "type": "array"
        },
        "papers_without_artifact_ids": {
          "description": "List of paper index IDs for non-artifact papers. References papers.json.",
          "items": {
            "type": "integer"
          },
          "title": "Papers Without Artifact Ids",
          "type": "array"
        }
      },
      "required": [
        "name",
        "affiliation",
        "conferences",
        "years",
        "artifact_count",
        "total_papers",
        "artifact_pct",
        "artifact_citations",
        "badges_available",
        "badges_functional",
        "badges_reproducible",
        "category",
        "display_name",
        "total_papers_by_conf",
        "total_papers_by_conf_year",
        "repro_pct",
        "functional_pct",
        "year_range",
        "recent_count"
      ],
      "title": "AuthorStats",
      "type": "object"
    }
  }
}
