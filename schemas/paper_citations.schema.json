{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reprodb.github.io/data-schemas/schemas/paper_citations.schema.json",
  "$comment": "Validates: assets/data/paper_citations.json",
  "version": "0.1.0",
  "title": "PaperCitation Collection",
  "description": "Citation data for a single paper via Google Scholar.",
  "type": "array",
  "items": {
    "$ref": "#/$defs/PaperCitation"
  },
  "$defs": {
    "PaperCitation": {
      "additionalProperties": false,
      "description": "Citation data for a single paper via Google Scholar.",
      "properties": {
        "title": {
          "description": "Paper title.",
          "title": "Title",
          "type": "string"
        },
        "normalized_title": {
          "description": "Lowercased, stripped title for deduplication.",
          "title": "Normalized Title",
          "type": "string"
        },
        "conference": {
          "description": "Conference name.",
          "title": "Conference",
          "type": "string"
        },
        "year": {
          "description": "Publication year.",
          "title": "Year",
          "type": "integer"
        },
        "category": {
          "default": "",
          "description": "Paper category/track.",
          "title": "Category",
          "type": "string"
        },
        "badges": {
          "default": "",
          "description": "Comma-separated badge names.",
          "title": "Badges",
          "type": "string"
        },
        "cited_by_count": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Citation count from Google Scholar.",
          "title": "Cited By Count"
        },
        "source": {
          "default": "",
          "description": "Source used for lookup (e.g. 'scholar').",
          "title": "Source",
          "type": "string"
        },
        "error": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Error message if lookup failed.",
          "title": "Error"
        }
      },
      "required": [
        "title",
        "normalized_title",
        "conference",
        "year"
      ],
      "title": "PaperCitation",
      "type": "object"
    }
  }
}
