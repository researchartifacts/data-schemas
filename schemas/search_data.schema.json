{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reprodb.github.io/data-schemas/schemas/search_data.schema.json",
  "title": "SearchEntry Collection",
  "description": "Array of SearchEntry records. Each element: Searchable artifact entry with paper metadata, badges, author names, and institutional affiliations.",
  "version": "0.1.1",
  "type": "array",
  "items": {
    "$ref": "#/$defs/SearchEntry"
  },
  "$defs": {
    "SearchEntry": {
      "additionalProperties": false,
      "description": "Searchable artifact entry with paper metadata, badges, author names, and institutional affiliations.",
      "properties": {
        "title": {
          "description": "Paper title.",
          "title": "Title",
          "type": "string"
        },
        "conference": {
          "description": "Conference abbreviation.",
          "title": "Conference",
          "type": "string"
        },
        "category": {
          "description": "Research domain.",
          "enum": [
            "systems",
            "security"
          ],
          "title": "Category",
          "type": "string"
        },
        "year": {
          "description": "Publication year.",
          "title": "Year",
          "type": "integer"
        },
        "badges": {
          "description": "Artifact evaluation badges. Canonical values: 'available', 'functional', 'reproduced', 'reusable', 'replicated'.",
          "items": {
            "type": "string"
          },
          "title": "Badges",
          "type": "array"
        },
        "artifact_urls": {
          "description": "All artifact-related URLs (repositories, archives, DOIs).",
          "items": {
            "type": "string"
          },
          "title": "Artifact Urls",
          "type": "array"
        },
        "doi_url": {
          "description": "Paper DOI URL. Empty string if not available.",
          "title": "Doi Url",
          "type": "string"
        },
        "authors": {
          "description": "Author names (DBLP disambiguation suffixes removed).",
          "items": {
            "type": "string"
          },
          "title": "Authors",
          "type": "array"
        },
        "affiliations": {
          "description": "Sorted unique institution affiliations of all authors.",
          "items": {
            "type": "string"
          },
          "title": "Affiliations",
          "type": "array"
        },
        "paper_url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Paper DOI or direct link.",
          "title": "Paper Url"
        },
        "appendix_url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Supplementary materials URL.",
          "title": "Appendix Url"
        },
        "award": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Award designation, if any.",
          "title": "Award"
        }
      },
      "required": [
        "title",
        "conference",
        "category",
        "year",
        "badges",
        "artifact_urls",
        "doi_url",
        "authors",
        "affiliations"
      ],
      "title": "SearchEntry",
      "type": "object"
    }
  }
}
