{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reprodb.github.io/data-schemas/schemas/search_data.schema.json",
  "title": "SearchEntry Collection",
  "description": "Array of SearchEntry records. Each element: Searchable artifact entry with paper metadata, badges, author names, and institutional affiliations.",
  "version": "0.1.4",
  "type": "array",
  "items": {
    "$ref": "#/$defs/SearchEntry"
  },
  "$defs": {
    "SearchEntry": {
      "additionalProperties": false,
      "description": "Searchable artifact entry with paper metadata, badges, author names, and institutional affiliations.",
      "properties": {
        "title": {
          "description": "Full paper title as it appears in the proceedings.",
          "examples": [
            "Understanding and Detecting Software Upgrade Failures in Distributed Systems"
          ],
          "title": "Title",
          "type": "string"
        },
        "conference": {
          "description": "Conference abbreviation, e.g. 'OSDI', 'NDSS', 'USENIXSEC'.",
          "examples": [
            "OSDI"
          ],
          "title": "Conference",
          "type": "string"
        },
        "category": {
          "description": "Research domain: 'systems' or 'security'.",
          "enum": [
            "systems",
            "security"
          ],
          "title": "Category",
          "type": "string"
        },
        "year": {
          "description": "Publication year, e.g. 2023.",
          "examples": [
            2023
          ],
          "title": "Year",
          "type": "integer"
        },
        "badges": {
          "description": "Artifact evaluation badges awarded by the AE committee. Canonical lowercase values: 'available', 'functional', 'reproduced', 'reusable', 'replicated'.",
          "examples": [
            [
              "available",
              "functional",
              "reproduced"
            ]
          ],
          "items": {
            "type": "string"
          },
          "title": "Badges",
          "type": "array"
        },
        "artifact_urls": {
          "description": "Artifact URLs (repos, archives, DOIs), e.g. ['https://github.com/org/repo', 'https://doi.org/10.5281/zenodo.12345'].",
          "examples": [
            [
              "https://github.com/org/repo",
              "https://doi.org/10.5281/zenodo.12345"
            ]
          ],
          "items": {
            "type": "string"
          },
          "title": "Artifact Urls",
          "type": "array"
        },
        "doi_url": {
          "description": "Paper DOI URL, e.g. 'https://doi.org/10.1145/...'. Empty string if not available.",
          "examples": [
            "https://doi.org/10.1145/3600006.3613152"
          ],
          "title": "Doi Url",
          "type": "string"
        },
        "authors": {
          "description": "Author names with disambiguation suffixes removed, e.g. ['Mathias Payer', 'Haibo Chen'].",
          "examples": [
            [
              "Mathias Payer",
              "Haibo Chen"
            ]
          ],
          "items": {
            "type": "string"
          },
          "title": "Authors",
          "type": "array"
        },
        "affiliations": {
          "description": "Sorted unique institution affiliations of all authors, e.g. ['EPFL', 'MIT'].",
          "examples": [
            [
              "EPFL",
              "MIT"
            ]
          ],
          "items": {
            "type": "string"
          },
          "title": "Affiliations",
          "type": "array"
        },
        "paper_url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Paper DOI URL or direct link to the paper. Null if not available.",
          "examples": [
            "https://doi.org/10.1145/3600006.3613152"
          ],
          "title": "Paper Url"
        },
        "appendix_url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "URL to supplementary materials or appendix. Null if not available.",
          "examples": [
            "https://arxiv.org/abs/2301.12345"
          ],
          "title": "Appendix Url"
        },
        "award": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Award designation such as 'Distinguished Artifact'. Null if no award.",
          "examples": [
            "Distinguished Artifact"
          ],
          "title": "Award"
        }
      },
      "required": [
        "title",
        "conference",
        "category",
        "year",
        "badges",
        "artifact_urls",
        "doi_url",
        "authors",
        "affiliations"
      ],
      "title": "SearchEntry",
      "type": "object"
    }
  }
}
