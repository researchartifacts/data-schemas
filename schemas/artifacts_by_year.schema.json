{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reprodb.github.io/data-schemas/schemas/artifacts_by_year.schema.json",
  "title": "YearCount Collection",
  "description": "Artifact count for a single year with systems/security breakdown.",
  "type": "array",
  "items": {
    "$ref": "#/$defs/YearCount"
  },
  "$defs": {
    "YearCount": {
      "additionalProperties": false,
      "description": "Artifact count for a single year with systems/security breakdown.",
      "properties": {
        "year": {
          "description": "Publication year.",
          "title": "Year",
          "type": "integer"
        },
        "count": {
          "description": "Total artifacts for this year.",
          "minimum": 0,
          "title": "Count",
          "type": "integer"
        },
        "systems": {
          "description": "Artifacts from systems conferences.",
          "minimum": 0,
          "title": "Systems",
          "type": "integer"
        },
        "security": {
          "description": "Artifacts from security conferences.",
          "minimum": 0,
          "title": "Security",
          "type": "integer"
        }
      },
      "required": [
        "year",
        "count",
        "systems",
        "security"
      ],
      "title": "YearCount",
      "type": "object"
    }
  }
}
