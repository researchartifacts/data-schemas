{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reprodb.github.io/data-schemas/schemas/ae_members.schema.json",
  "title": "AEMember Collection",
  "description": "Array of AEMember records. Each element: An Artifact Evaluation committee member with service history and institutional affiliation.",
  "version": "0.1.1",
  "type": "array",
  "items": {
    "$ref": "#/$defs/AEMember"
  },
  "$defs": {
    "AEMembership": {
      "additionalProperties": false,
      "description": "A single AE committee membership record.",
      "properties": {
        "conference": {
          "description": "Conference abbreviation (e.g. 'OSDI', 'USENIXSEC').",
          "title": "Conference",
          "type": "string"
        },
        "year": {
          "description": "Year of service.",
          "title": "Year",
          "type": "integer"
        },
        "role": {
          "description": "Role on the committee: 'chair' or 'member'.",
          "title": "Role",
          "type": "string"
        }
      },
      "required": [
        "conference",
        "year",
        "role"
      ],
      "title": "AEMembership",
      "type": "object"
    },
    "AEMember": {
      "additionalProperties": false,
      "description": "An Artifact Evaluation committee member with service history and institutional affiliation.",
      "properties": {
        "name": {
          "description": "Full name of the AE member.",
          "title": "Name",
          "type": "string"
        },
        "display_name": {
          "description": "Display name (may differ from canonical name).",
          "title": "Display Name",
          "type": "string"
        },
        "affiliation": {
          "description": "Current institutional affiliation.",
          "title": "Affiliation",
          "type": "string"
        },
        "total_memberships": {
          "description": "Total number of AE committee memberships.",
          "minimum": 0,
          "title": "Total Memberships",
          "type": "integer"
        },
        "chair_count": {
          "description": "Number of times served as AE chair.",
          "minimum": 0,
          "title": "Chair Count",
          "type": "integer"
        },
        "conferences": {
          "description": "AE committee memberships, one per conference-year served.",
          "items": {
            "$ref": "#/$defs/AEMembership"
          },
          "title": "Conferences",
          "type": "array"
        },
        "years": {
          "additionalProperties": {
            "type": "integer"
          },
          "description": "Year (as string, e.g. '2023') → number of memberships that year.",
          "title": "Years",
          "type": "object"
        },
        "area": {
          "description": "Research area: 'systems', 'security', or 'both'.",
          "title": "Area",
          "type": "string"
        },
        "first_year": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Earliest year of AE service.",
          "title": "First Year"
        },
        "last_year": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Most recent year of AE service.",
          "title": "Last Year"
        }
      },
      "required": [
        "name",
        "display_name",
        "affiliation",
        "total_memberships",
        "chair_count",
        "conferences",
        "years",
        "area"
      ],
      "title": "AEMember",
      "type": "object"
    }
  }
}
